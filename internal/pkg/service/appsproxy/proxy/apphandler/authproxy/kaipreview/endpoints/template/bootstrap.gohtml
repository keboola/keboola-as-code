<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Loading preview…</title>
  <style>
    html, body { margin: 0; padding: 0; background: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    .status { display: flex; align-items: center; justify-content: center; height: 100vh; color: #888; font-size: 14px; text-align: center; padding: 0 24px; }
  </style>
</head>
<body>
<div class="status" id="status">Loading preview…</div>
<script>
(function () {
  "use strict";

  // Server-rendered: the list of IDE origins this preview is allowed to handshake with.
  var ALLOWED_ORIGINS = {{ .AllowedOriginsJSON }};

  var EXCHANGE_PATH = "/_proxy/kai-preview/exchange";
  var status = document.getElementById("status");
  var didHandshake = false;
  var broadcastTimer = null;

  function setStatus(text) { if (status) { status.textContent = text; } }

  function originAllowed(origin) {
    for (var i = 0; i < ALLOWED_ORIGINS.length; i++) {
      if (ALLOWED_ORIGINS[i] === origin) { return true; }
    }
    return false;
  }

  function broadcastReady() {
    if (!window.parent || window.parent === window) {
      setStatus("This preview only loads from the Keboola UI.");
      return;
    }
    for (var i = 0; i < ALLOWED_ORIGINS.length; i++) {
      try { window.parent.postMessage({ type: "kai-preview-ready" }, ALLOWED_ORIGINS[i]); }
      catch (e) { /* targetOrigin mismatch is benign */ }
    }
  }

  // Exponential-backoff broadcast: 100ms, 300ms, 700ms, 1500ms, then 2000ms cap.
  // Total coverage ≈ 10s without flooding the parent with messages.
  var BACKOFF_DELAYS = [100, 300, 700, 1500, 2000];
  var broadcastAttempt = 0;

  function scheduleBroadcast() {
    var delay = BACKOFF_DELAYS[Math.min(broadcastAttempt, BACKOFF_DELAYS.length - 1)];
    broadcastAttempt++;
    broadcastTimer = setTimeout(function () {
      if (didHandshake) { return; }
      broadcastReady();
      // Give up after ~10s (sum of all delays).
      if (broadcastAttempt <= 6) {
        scheduleBroadcast();
      } else {
        setStatus("This preview only loads from the Keboola UI.");
      }
    }, delay);
  }

  function onMessage(event) {
    if (didHandshake) { return; }
    // C3: only accept messages from the window that framed us (defence in depth).
    if (event.source !== window.parent) { return; }
    if (!originAllowed(event.origin)) { return; }
    if (!event.data || event.data.type !== "kai-preview-token" || typeof event.data.token !== "string") { return; }

    // I3: loop-detection — if the browser silently blocks the partitioned cookie
    // (Safari ITP etc.) the iframe would cycle: exchange → redirect → bootstrap →
    // exchange → … Detect this with sessionStorage and bail out early.
    var LOOP_KEY = "kbc-kai-preview-attempts";
    try {
      // Reset the counter when loaded at the canonical bootstrap path (fresh
      // handshake initiated by kbc-ui).  In a redirect loop the shim is served
      // as a fallback at "/" so the counter keeps accumulating there.
      if (window.location.pathname === "/_proxy/kai-preview/bootstrap") {
        sessionStorage.removeItem(LOOP_KEY);
      }
      var attempts = parseInt(sessionStorage.getItem(LOOP_KEY) || "0", 10);
      if (attempts >= 3) {
        setStatus("Preview unavailable — your browser may be blocking storage for embedded apps. Try disabling tracking protection for this site.");
        return;
      }
      sessionStorage.setItem(LOOP_KEY, String(attempts + 1));
    } catch (e) {
      // sessionStorage blocked entirely (e.g. strict mode): treat as attempt 0 and continue.
    }

    didHandshake = true;
    if (broadcastTimer) { clearTimeout(broadcastTimer); broadcastTimer = null; }

    fetch(EXCHANGE_PATH, {
      method: "POST",
      credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ token: event.data.token })
    }).then(function (r) {
      if (!r.ok) {
        setStatus("Preview authorization failed (" + r.status + "). Reload the parent page.");
        return;
      }
      window.location.replace("/");
    }).catch(function () {
      setStatus("Preview authorization failed — network error.");
    });
  }

  window.addEventListener("message", onMessage);
  broadcastReady();
  scheduleBroadcast();
})();
</script>
</body>
</html>
