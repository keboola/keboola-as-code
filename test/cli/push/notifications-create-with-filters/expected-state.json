{
  "branches": [
    {
      "branch": {
        "name": "Main",
        "description": "",
        "isDefault": true
      },
      "configs": [
        {
          "componentId": "ex-generic-v2",
          "name": "empty",
          "description": "",
          "changeDescription": "",
