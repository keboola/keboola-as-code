        {
          "field": "job.component.id",
          "value": "ex-generic-v2",
          "operator": "=="
        },
        {
          "field": "job.configuration.id",
          "value": "%%TEST_BRANCH_MAIN_CONFIG_EMPTY_ID%%",
          "operator": "=="
        },
        {
          "field": "job.token.id",
          "value": "123",
          "operator": "=="
        }
      ],
      "recipient": {
        "channel": "email",
        "address": "alerts@example.com"
      }
    }
  ]
